#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Rclone 上传后处理模块 / Rclone Upload Post-processing Module

通过 rclone 将录制完成的视频上传至 PikPak 云盘。
- 自动从文件名提取主播名（去除 _YYYYMMDD_HHMMSS 后缀）
- 在远程目录下按主播名创建子文件夹
- 支持重试机制
- 上传成功后可选删除本地文件
- 通过 stdout 协议上报进度

协议 / Protocol:
  --describe           输出模块元数据 JSON
  PP_INPUT 环境变量     输入视频文件路径
  PP_PARAM_* 环境变量   模块参数
  stdout: OUTPUT:path   成功后输出视频路径
  stdout: PROGRESS:d/t  进度上报 (total=10000)
  stdout: STATUS:text   状态文字
  stdout: DELETE_INPUT  请求主程序删除输入文件
"""

import sys
import os
import re
import json
import subprocess
import time

PROGRESS_SCALE = 10000

DESCRIBE = {
    "id": "rclone_upload",
    "name": "Rclone 上传 0.1.0",
    "description": "通过 rclone 将视频上传至 PikPak 等云盘，自动按主播名分类存储",
    "params": [
        {
            "key": "remote_name",
            "label": "Rclone 远程名称",
            "type": "string",
            "default": "pikpak",
        },
        {
            "key": "base_dir",
            "label": "云盘目标目录",
            "type": "string",
            "default": "StripchatRecorder",
        },
        {
            "key": "rclone_path",
            "label": "rclone 路径",
            "type": "string",
            "default": "rclone",
        },
        {
            "key": "max_retries",
            "label": "最大重试次数",
            "type": "number",
            "default": 3,
        },
        {
            "key": "delete_after_upload",
            "label": "上传成功后删除本地文件",
            "type": "boolean",
            "default": False,
        },
        {
            "key": "transfers",
            "label": "并行传输数",
            "type": "number",
            "default": 2,
        },
    ],
    "i18n": {
        "en-US": {
            "name": "Rclone Upload 0.1.0",
            "description": "Upload videos to cloud storage via rclone, auto-categorized by streamer name",
            "params": {
                "remote_name": {"label": "Rclone Remote Name"},
                "base_dir": {"label": "Cloud Target Directory"},
                "rclone_path": {"label": "Rclone Path"},
                "max_retries": {"label": "Max Retries"},
                "delete_after_upload": {"label": "Delete local file after upload"},
                "transfers": {"label": "Parallel Transfers"},
            },
        },
    },
}


def parse_stem(stem: str):
    """
    从文件名（不含扩展名）中提取主播名和时间戳。
    格式: {model_name}_{YYYYMMDD}_{HHMMSS}
    """
    parts = stem.split("_")
    if len(parts) >= 3:
        date_str = parts[-2]
        time_str = parts[-1]
        if (
            len(date_str) == 8
            and date_str.isdigit()
            and len(time_str) == 6
            and time_str.isdigit()
        ):
            model = "_".join(parts[:-2])
            return model
    return stem


def emit_progress(done: int, total: int = PROGRESS_SCALE):
    print(f"PROGRESS:{done}/{total}", flush=True)


def emit_status(text: str):
    print(f"STATUS:{text}", flush=True)


def emit_output(path: str):
    print(f"OUTPUT:{path}", flush=True)


def param(key: str, default=""):
    val = os.environ.get(f"PP_PARAM_{key.upper()}", "")
    if val == "":
        return default
    return val


def param_int(key: str, default: int) -> int:
    try:
        return int(param(key, str(default)))
    except (ValueError, TypeError):
        return default


def param_bool(key: str, default: bool) -> bool:
    return param(key, str(default)).lower() in ("true", "1", "yes", "on")


def ensure_remote_folder(rclone_path: str, remote: str, base_dir: str, folder_name: str):
    """确保远程目录存在"""
    remote_path = f"{remote}:{base_dir}/{folder_name}"
    try:
        result = subprocess.run(
            [rclone_path, "mkdir", remote_path],
            capture_output=True,
            text=True,
            timeout=120,
        )
        if result.returncode != 0:
            sys.stderr.write(f"mkdir failed: {result.stderr}\n")
            return False
        return True
    except Exception as e:
        sys.stderr.write(f"mkdir exception: {e}\n")
        return False


def upload_file(
    rclone_path: str,
    local_path: str,
    remote: str,
    base_dir: str,
    folder_name: str,
    transfers: int,
):
    """使用 rclone copyto 上传文件，实时解析进度"""
    remote_dest = f"{remote}:{base_dir}/{folder_name}/{os.path.basename(local_path)}"

    cmd = [
        rclone_path,
        "copyto",
        local_path,
        remote_dest,
        "--progress",
        "--transfers",
        str(transfers),
        "--stats",
        "1s",
        "--no-traverse",
        "--verbose",
    ]

    try:
        proc = subprocess.Popen(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            bufsize=1,
            universal_newlines=True,
        )
    except Exception as e:
        return False, f"Failed to spawn rclone: {e}"

    last_progress = 0
    stderr_lines = []

    while True:
        line = proc.stderr.readline()
        if not line:
            if proc.poll() is not None:
                break
            continue

        stderr_lines.append(line.rstrip())
        line_stripped = line.strip()

        # 解析 rclone 进度: Transferred 123.456 MiB / 789.012 MiB (15.6%), 2.3 MiB/s, ETA 4m30s
        progress_match = re.search(
            r"Transferred\s+[\d.]+\s*\w+\s*/\s*[\d.]+\s*\w+\s*\(([\d.]+)%\)",
            line_stripped,
        )
        if progress_match:
            try:
                pct = float(progress_match.group(1))
                progress = int(pct * PROGRESS_SCALE / 100.0)
                if progress > last_progress:
                    last_progress = progress
                    emit_progress(progress)
            except ValueError:
                pass

            speed_match = re.search(r"([\d.]+\s*\w+/s)", line_stripped)
            if speed_match:
                emit_status(f"↑ {speed_match.group(1)}")

        if "ERROR" in line_stripped or "error" in line_stripped.lower():
            sys.stderr.write(f"rclone: {line_stripped}\n")

    proc.wait()

    if proc.returncode == 0:
        emit_progress(PROGRESS_SCALE)
        return True, "Upload OK"
    else:
        error_msg = "\n".join(l for l in stderr_lines if "ERROR" in l or "error" in l.lower())
        if not error_msg:
            error_msg = "\n".join(stderr_lines[-5:]) if stderr_lines else f"rclone exit {proc.returncode}"
        return False, error_msg


def run():
    input_str = os.environ.get("PP_INPUT", "")
    if not input_str:
        sys.stderr.write("PP_INPUT not set\n")
        sys.exit(1)

    input_path = os.path.abspath(input_str)
    if not os.path.exists(input_path):
        sys.stderr.write(f"Input file not found: {input_path}\n")
        sys.exit(1)

    remote_name = param("remote_name", "pikpak")
    base_dir = param("base_dir", "StripchatRecorder")
    rclone_path = param("rclone_path", "rclone")
    max_retries = param_int("max_retries", 3)
    delete_after = param_bool("delete_after_upload", False)
    transfers = param_int("transfers", 2)

    stem = os.path.splitext(os.path.basename(input_path))[0]
    streamer_name = parse_stem(stem)
    if not streamer_name:
        streamer_name = "unknown"

    sys.stderr.write(
        f"[rclone_upload] file={input_path}, streamer={streamer_name}, "
        f"target={remote_name}:{base_dir}/{streamer_name}/\n"
    )

    emit_progress(0)
    emit_status(f"准备上传至 {streamer_name}/")

    ensure_remote_folder(rclone_path, remote_name, base_dir, streamer_name)

    emit_progress(100)
    emit_status("正在上传...")

    last_error = ""
    for attempt in range(1, max_retries + 1):
        sys.stderr.write(f"Upload attempt {attempt}/{max_retries}\n")

        success, message = upload_file(
            rclone_path, input_path, remote_name, base_dir, streamer_name, transfers
        )

        if success:
            emit_status("上传完成 ✓")
            if delete_after:
                print("DELETE_INPUT", flush=True)
            else:
                emit_output(input_path)
            sys.stderr.write(f"Upload success: {input_path} -> {remote_name}:{base_dir}/{streamer_name}/\n")
            return

        last_error = message
        if attempt < max_retries:
            wait_time = 10 * attempt
            emit_status(f"重试中 ({attempt}/{max_retries})，{wait_time}s 后重试...")
            sys.stderr.write(f"Upload failed (attempt {attempt}/{max_retries}): {message}\n")
            time.sleep(wait_time)

    emit_status("上传失败 ✗")
    sys.stderr.write(f"Upload failed after {max_retries} attempts: {last_error}\n")
    print(f"Rclone 上传失败: {last_error}", flush=True)
    emit_output(input_path)
    sys.exit(1)


def main():
    args = sys.argv[1:]
    if args and args[0] == "--describe":
        print(json.dumps(DESCRIBE, ensure_ascii=False, indent=2))
        return

    try:
        run()
    except Exception as e:
        sys.stderr.write(f"Rclone module error: {e}\n")
        input_str = os.environ.get("PP_INPUT", "")
        if input_str:
            emit_output(input_str)
        sys.exit(1)


if __name__ == "__main__":
    main()
